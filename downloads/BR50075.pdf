    <!-- JavaScript -->
    <script>
      // Data varian
      const variantData = {
        'S-Merah Kotak': { price: 10000, sku: 'FLN001-S-MRH', img: 'https://via.placeholder.com/600x800?text=Kemeja+Merah+S' },
        'S-Biru Kotak': { price: 10000, sku: 'FLN001-S-BRU', img: 'https://via.placeholder.com/600x800?text=Kemeja+Biru+S' },
        'S-Hitam Kotak': { price: 10000, sku: 'FLN001-S-HTM', img: 'https://via.placeholder.com/600x800?text=Kemeja+Hitam+S' },
        'M-Merah Kotak': { price: 10000, sku: 'FLN001-M-MRH', img: 'https://via.placeholder.com/600x800?text=Kemeja+Merah+M' },
        'M-Biru Kotak': { price: 10000, sku: 'FLN001-M-BRU', img: 'https://via.placeholder.com/600x800?text=Kemeja+Biru+M' },
        'M-Hitam Kotak': { price: 10000, sku: 'FLN001-M-HTM', img: 'https://via.placeholder.com/600x800?text=Kemeja+Hitam+M' },
        'L-Merah Kotak': { price: 10000, sku: 'FLN001-L-MRH', img: 'https://via.placeholder.com/600x800?text=Kemeja+Merah+L' },
        'L-Biru Kotak': { price: 10000, sku: 'FLN001-L-BRU', img: 'https://via.placeholder.com/600x800?text=Kemeja+Biru+L' },
        'L-Hitam Kotak': { price: 10000, sku: 'FLN001-L-HTM', img: 'https://via.placeholder.com/600x800?text=Kemeja+Hitam+L' },
        'XL-Merah Kotak': { price: 10000, sku: 'FLN001-XL-MRH', img: 'https://via.placeholder.com/600x800?text=Kemeja+Merah+XL' },
        'XL-Biru Kotak': { price: 10000, sku: 'FLN001-XL-BRU', img: 'https://via.placeholder.com/600x800?text=Kemeja+Biru+XL' },
        'XL-Hitam Kotak': { price: 10000, sku: 'FLN001-XL-HTM', img: 'https://via.placeholder.com/600x800?text=Kemeja+Hitam+XL' }
      };

      let currentSize = 'S';
      let currentColor = 'Merah Kotak';

      function updateVariant(size, color) {
        const key = size + '-' + color;
        const variant = variantData[key];
        if (!variant) return;

        // Update harga
        document.getElementById('productPrice').innerHTML = `Rp${variant.price.toLocaleString('id-ID')} <small>Rp100.000</small>`;

        // Update gambar utama
        const mainImg = document.querySelector('.main-image img');
        mainImg.src = variant.img;
        mainImg.srcset = variant.img.replace('600x800', '400x533') + ' 400w, ' + variant.img + ' 600w, ' + variant.img.replace('600x800', '800x1067') + ' 800w';

        // Update tombol aktif
        document.querySelectorAll('.variant-btn').forEach(btn => {
          btn.classList.remove('active');
          btn.setAttribute('aria-pressed', 'false');
        });
        document.getElementById(`size-${size}`).classList.add('active');
        document.getElementById(`size-${size}`).setAttribute('aria-pressed', 'true');
        document.getElementById(`color-${color.split(' ')[0]}`).classList.add('active');
        document.getElementById(`color-${color.split(' ')[0]}`).setAttribute('aria-pressed', 'true');

        // Update URL
        const url = new URL(window.location);
        url.searchParams.set('size', size);
        url.searchParams.set('color', color);
        window.history.pushState({}, '', url);
      }

      window.selectVariant = function(size, color) {
        currentSize = size;
        currentColor = color;
        updateVariant(size, color);
      };

      // Baca parameter URL saat load
      window.addEventListener('load', function() {
        const params = new URLSearchParams(window.location.search);
        const sizeParam = params.get('size');
        const colorParam = params.get('color');
        if (sizeParam && colorParam && variantData[sizeParam + '-' + colorParam]) {
          currentSize = sizeParam;
          currentColor = colorParam;
          updateVariant(sizeParam, colorParam);
        }
      });

      // Fungsi-fungsi asli (tetap)
      function changeImage(thumb, imgSrc) {
        let mainImg = document.querySelector('.main-image img');
        mainImg.src = imgSrc;
        mainImg.srcset = imgSrc.replace('600x800', '400x533') + ' 400w, ' + imgSrc + ' 600w, ' + imgSrc.replace('600x800', '800x1067') + ' 800w';
        document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
        thumb.classList.add('active');
      }

      function openTab(event, tabId) {
        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
        document.querySelectorAll('.tab-header').forEach(header => {
          header.classList.remove('active');
          header.setAttribute('aria-selected', 'false');
        });
        document.getElementById(tabId).classList.add('active');
        event.target.classList.add('active');
        event.target.setAttribute('aria-selected', 'true');
      }

      function toggleFAQ(element) {
        let answer = element.nextElementSibling;
        if (answer.style.display === 'none' || answer.style.display === '') {
          answer.style.display = 'block';
          element.querySelector('span:last-child').innerHTML = '▼';
          element.setAttribute('aria-expanded', 'true');
        } else {
          answer.style.display = 'none';
          element.querySelector('span:last-child').innerHTML = '▶';
          element.setAttribute('aria-expanded', 'false');
        }
      }

      window.onload = function() {
        document.querySelectorAll('.faq-answer').forEach(ans => ans.style.display = 'block');
        document.querySelectorAll('.faq-question').forEach(q => q.setAttribute('aria-expanded', 'true'));
      };
    </script>
