    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap');

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: linear-gradient(135deg, #f9fafc 0%, #f2f4f8 100%);
        color: #1e293b;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        line-height: 1.5;
      }

      .container {
        max-width: 1280px;
        margin: 0 auto;
        padding: 24px;
      }

      .header {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 60px;
        padding: 16px 28px;
        margin-bottom: 28px;
        box-shadow: 0 15px 35px -10px rgba(0, 0, 0, 0.1);
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: all 0.3s ease;
      }

      .header:hover {
        box-shadow: 0 20px 40px -12px rgba(220, 38, 38, 0.2);
      }

      .logo {
        font-size: 1.7rem;
        font-weight: 700;
        background: linear-gradient(135deg, #dc2626, #f87171);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-decoration: none;
        transition: opacity 0.2s;
      }

      .logo:hover {
        opacity: 0.8;
      }

      .search-bar {
        background: rgba(241, 245, 249, 0.7);
        backdrop-filter: blur(4px);
        padding: 10px 20px;
        border-radius: 40px;
        width: 300px;
        border: 1px solid rgba(255, 255, 255, 0.6);
        transition: all 0.3s;
      }

      .search-bar:focus-within {
        box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.2);
        border-color: #dc2626;
      }

      /* Breadcrumb */
      .breadcrumb {
        margin-bottom: 24px;
        font-size: 0.95rem;
        background: white;
        padding: 12px 24px;
        border-radius: 40px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.03);
        display: inline-block;
        transition: box-shadow 0.2s;
      }
      .breadcrumb:hover {
        box-shadow: 0 8px 22px rgba(220,38,38,0.08);
      }
      .breadcrumb ol {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
      }
      .breadcrumb li {
        display: flex;
        align-items: center;
      }
      .breadcrumb li:not(:last-child)::after {
        content: "›";
        margin-left: 8px;
        color: #94a3b8;
        font-size: 1.2rem;
        line-height: 1;
      }
      .breadcrumb a {
        color: #dc2626;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .breadcrumb a:hover {
        color: #b91c1c;
        text-decoration: underline;
        transform: translateY(-1px);
      }
      .breadcrumb [aria-current="page"] {
        color: #64748b;
        font-weight: 600;
        cursor: default;
      }

      .product-detail {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 36px;
        background: white;
        border-radius: 48px;
        padding: 40px;
        box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.2);
        margin-bottom: 40px;
        border: 1px solid rgba(255,255,255,0.5);
        transition: transform 0.3s ease;
      }

      .product-detail:hover {
        transform: translateY(-5px);
      }

      .product-gallery {
        display: flex;
        flex-direction: column;
      }

      .main-image {
        width: 100%;
        border-radius: 32px;
        overflow: hidden;
        background: #f8fafc;
        margin-bottom: 20px;
        cursor: zoom-in;
        box-shadow: 0 20px 30px -10px rgba(0,0,0,0.15);
        transition: box-shadow 0.3s;
      }

      .main-image:hover {
        box-shadow: 0 25px 40px -8px rgba(220, 38, 38, 0.3);
      }

      .main-image img {
        width: 100%;
        height: auto;
        display: block;
        transition: transform 0.5s cubic-bezier(0.2, 0.9, 0.4, 1);
      }

      .main-image:hover img {
        transform: scale(1.07);
      }

      .thumbnail-list {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .thumbnail {
        width: 90px;
        height: 90px;
        border-radius: 24px;
        overflow: hidden;
        border: 3px solid transparent;
        cursor: pointer;
        opacity: 0.7;
        transition: all 0.3s;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
      }

      .thumbnail.active {
        border-color: #dc2626;
        opacity: 1;
        transform: scale(1.05);
        box-shadow: 0 10px 25px -5px #dc262680;
      }

      .thumbnail:hover {
        opacity: 0.9;
        transform: scale(1.02);
      }

      .thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .product-info h1 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 12px;
        background: linear-gradient(135deg, #1e293b, #334155);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .rating {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        background: #f1f5f9;
        padding: 8px 18px;
        border-radius: 40px;
        width: fit-content;
      }

      .stars {
        display: flex;
        gap: 4px;
        color: #fbbf24;
        font-size: 1.2rem;
      }

      .price {
        font-size: 2.5rem;
        font-weight: 800;
        color: #dc2626;
        margin-bottom: 20px;
        display: flex;
        align-items: baseline;
        gap: 12px;
      }

      .price small {
        font-size: 1.2rem;
        font-weight: 500;
        color: #94a3b8;
        text-decoration: line-through;
      }

      .trust-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin: 28px 0;
        padding: 20px 0;
        border-top: 2px solid #eef2f6;
        border-bottom: 2px solid #eef2f6;
      }

      .badge {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f8fafc;
        padding: 8px 20px;
        border-radius: 40px;
        font-size: 0.95rem;
        font-weight: 500;
        color: #1e293b;
        box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        transition: all 0.2s;
      }

      .badge:hover {
        background: #dc2626;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -8px #dc2626;
      }

      .badge i {
        font-size: 1.2rem;
      }

      .curator-section {
        margin: 30px 0 20px;
        padding: 20px;
        background: linear-gradient(135deg, #fef2f2, #fef2f2);
        border-radius: 40px;
        border: 1px dashed #dc2626;
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
      }
      .curator-image {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #dc2626;
      }
      .curator-info h4 {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
      }
      .curator-info p {
        color: #475569;
        font-size: 0.95rem;
      }

      .variation {
        margin: 24px 0;
      }

      .variation-title {
        font-weight: 600;
        margin-bottom: 12px;
        font-size: 1.1rem;
        color: #334155;
      }

      .variation-options {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .variant-btn {
        padding: 10px 28px;
        border: 2px solid #e2e8f0;
        background: white;
        border-radius: 60px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.2, 0.9, 0.4, 1);
        font-weight: 600;
        color: #334155;
        min-width: 60px;
        min-height: 54px;
      }

      .variant-btn:hover, .variant-btn.active {
        border-color: #dc2626;
        background: #fef2f2;
        color: #dc2626;
        box-shadow: 0 8px 18px -8px #dc2626;
        transform: translateY(-2px);
      }

      .quantity {
        display: flex;
        align-items: center;
        gap: 18px;
        margin: 28px 0;
      }

      .quantity input {
        width: 80px;
        padding: 12px;
        border: 2px solid #e2e8f0;
        border-radius: 40px;
        text-align: center;
        font-weight: 600;
        font-size: 1.1rem;
        transition: all 0.2s;
      }

      .quantity input:focus {
        border-color: #dc2626;
        box-shadow: 0 0 0 4px rgba(220,38,38,0.1);
        outline: none;
      }

      .actions {
        display: flex;
        gap: 16px;
      }

      .btn {
        padding: 16px 32px;
        border: none;
        border-radius: 60px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        font-size: 1.1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 60px;
      }

      .btn-primary {
        background: linear-gradient(135deg, #dc2626, #ef4444);
        color: white;
        box-shadow: 0 12px 25px -8px #dc2626;
        flex: 1;
      }

      .btn-primary:hover {
        background: linear-gradient(135deg, #b91c1c, #dc2626);
        transform: translateY(-3px);
        box-shadow: 0 18px 30px -8px #dc2626;
      }

      .btn-outline {
        border: 2px solid #dc2626;
        color: #dc2626;
        background: white;
        box-shadow: 0 5px 15px rgba(0,0,0,0.02);
      }

      .btn-outline:hover {
        background: #fef2f2;
        transform: translateY(-3px);
        box-shadow: 0 12px 25px -10px #dc2626;
      }

      .share-buttons {
        display: flex;
        gap: 10px;
        margin-top: 15px;
      }
      .share-btn {
        background: #f1f5f9;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #475569;
        transition: all 0.2s;
        cursor: pointer;
      }
      .share-btn:hover {
        background: #dc2626;
        color: white;
        transform: translateY(-2px);
      }

      .product-tabs {
        background: white;
        border-radius: 48px;
        padding: 30px 35px;
        box-shadow: 0 25px 50px -15px rgba(0,0,0,0.1);
        margin-bottom: 40px;
      }

      .tab-headers {
        display: flex;
        gap: 12px;
        border-bottom: 2px solid #eef2f6;
        margin-bottom: 25px;
        flex-wrap: wrap;
      }

      .tab-header {
        padding: 14px 28px;
        font-weight: 600;
        cursor: pointer;
        color: #64748b;
        border-bottom: 4px solid transparent;
        transition: all 0.2s;
        border-radius: 40px 40px 0 0;
        font-size: 1.1rem;
      }

      .tab-header.active {
        color: #dc2626;
        border-bottom-color: #dc2626;
        background: linear-gradient(to top, #fef2f2, transparent);
      }

      .tab-header:hover:not(.active) {
        color: #334155;
        background: #f8fafc;
      }

      .review-item {
        border-bottom: 1px solid #fef2f2;
        padding: 20px 0;
        transition: background 0.2s;
      }

      .review-item:hover {
        background: #fef2f2;
        padding-left: 15px;
        border-radius: 24px;
      }

      .faq-question {
        font-weight: 600;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        cursor: pointer;
        padding: 16px 20px;
        background: #fef2f2;
        border-radius: 40px;
        transition: all 0.2s;
      }

      .faq-question:hover {
        background: #f1f5f9;
        transform: scale(1.01);
      }

      .faq-answer {
        color: #475569;
        margin: 8px 0 15px 25px;
        padding-right: 25px;
      }

      .ugc-gallery {
        margin-top: 40px;
        background: white;
        border-radius: 48px;
        padding: 30px;
        box-shadow: 0 25px 50px -15px rgba(0,0,0,0.1);
      }
      .ugc-gallery h2 {
        font-size: 1.8rem;
        font-weight: 700;
        margin-bottom: 25px;
        background: linear-gradient(135deg, #1e293b, #475569);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .ugc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 20px;
      }
      .ugc-item {
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 20px -8px rgba(0,0,0,0.1);
        transition: transform 0.3s;
      }
      .ugc-item:hover {
        transform: scale(1.03);
      }
      .ugc-item img {
        width: 100%;
        height: 150px;
        object-fit: cover;
        display: block;
      }

      .related-products {
        margin-top: 50px;
        background: white;
        border-radius: 48px;
        padding: 35px;
        box-shadow: 0 25px 50px -15px rgba(0,0,0,0.1);
      }

      .related-products h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 30px;
        background: linear-gradient(135deg, #1e293b, #475569);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 25px;
      }

      .product-card {
        background: white;
        border-radius: 32px;
        padding: 18px;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s;
        border: 1px solid #eef2f6;
        box-shadow: 0 10px 25px -12px rgba(0,0,0,0.1);
      }

      .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 35px -12px #dc262680;
        border-color: #dc2626;
      }

      .product-card img {
        width: 100%;
        height: auto;
        aspect-ratio: 3/4;
        object-fit: cover;
        border-radius: 24px;
        margin-bottom: 15px;
        transition: transform 0.3s;
      }

      .product-card:hover img {
        transform: scale(1.03);
      }

      .product-card h3 {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 8px;
      }

      .product-card .price {
        font-size: 1.2rem;
        color: #dc2626;
        font-weight: 700;
        margin-bottom: 5px;
      }

      .product-card .rating {
        background: transparent;
        padding: 0;
        font-size: 0.9rem;
      }

      /* NEW: CSS untuk bagian Tentang Kami */
      .about-us-section {
        background: white;
        border-radius: 48px;
        padding: 40px;
        margin-top: 50px;
        box-shadow: 0 25px 50px -15px rgba(0,0,0,0.1);
      }
      .about-us-section h2 {
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 30px;
        background: linear-gradient(135deg, #1e293b, #475569);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .about-us-section h3 {
        color: #dc2626;
        margin-bottom: 15px;
      }
      .tim-grid {
        display: flex;
        gap: 30px;
        flex-wrap: wrap;
        justify-content: center;
      }
      .tim-item {
        text-align: center;
        flex: 1 1 150px;
      }
      .tim-item img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #dc2626;
      }
      .testimoni-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
      }
      .testimoni-card {
        background: #fef2f2;
        border-radius: 32px;
        padding: 25px;
      }
      .testimoni-card i {
        color: #dc2626;
        font-size: 1.5rem;
      }
      .btn-about {
        background: #dc2626;
        color: white;
        padding: 14px 35px;
        border-radius: 60px;
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
        transition: all 0.2s;
      }
      .btn-about:hover {
        background: #b91c1c;
        transform: translateY(-2px);
      }

      .footer {
        text-align: center;
        padding: 30px;
        color: #64748b;
        margin-top: 50px;
        border-top: 2px solid #eef2f6;
      }

      .social-links {
        margin-top: 15px;
        display: flex;
        justify-content: center;
        gap: 25px;
      }

      .social-links a {
        color: #dc2626;
        text-decoration: none;
        font-size: 1.3rem;
        transition: transform 0.2s;
        display: inline-block;
      }

      .social-links a:hover {
        transform: translateY(-3px);
        color: #b91c1c;
      }

      @media (max-width: 768px) {
        .container {
          padding: 16px;
        }
        .product-detail {
          grid-template-columns: 1fr;
          padding: 25px;
          border-radius: 32px;
        }
        .header {
          flex-direction: column;
          gap: 15px;
          border-radius: 40px;
          padding: 18px;
        }
        .search-bar {
          width: 100%;
        }
        .product-grid {
          grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        }
        .tab-header {
          padding: 10px 18px;
          font-size: 1rem;
        }
        .curator-section {
          flex-direction: column;
          text-align: center;
        }
        .tim-grid {
          flex-direction: column;
          align-items: center;
        }
      }
    </style>
  </head>
