<script>
// **************************************************************************************************
// PREPARACION API IFRAME YOUTUBE
var tag = document.createElement('script');
tag.src = "https://www.youtube.com/iframe_api";
var firstScriptTag = document.getElementsByTagName('script')[0];
firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
//Variable global que se inicializa con el player al que accederan todos los metodos de control
var playerInstance;
function onYouTubeIframeAPIReadyCreateInstance() {
//videoId: $('#youtube-player-iframe-mini_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd').attr('videoid'),
playerInstance = new YT.Player('youtube-player-iframe-mini_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd', { events: {}});
}
// **************************************************************************************************
// GESTIÓN APP YOUTUBE
var yt_appData_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd = {videoList: []};
function pad_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(n){return n<10 ? '0'+n : n}
function yt_getAppVideoData_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(videoId)
{
for (var i = 0; i < yt_appData_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd.videoList.length; i++) {
if (yt_appData_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd.videoList[i].videoId==videoId) return yt_appData_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd.videoList[i];
}
}
// **************************************************************************************************
// PLAYLISTS
function yt_loadPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd()
{
var jsonURL="https://www.googleapis.com/youtube/v3/playlists?part=snippet&maxResults=20&channelId=&key=AIzaSyDtCXRz3PSPr4lTE4qzQG_wdcQKx0W_rLk";
var request = new XMLHttpRequest();
request.open('GET', jsonURL);
request.responseType = 'json';
request.send();
request.onload = function() {
if (request.status === 200) {
var playlists = request.response;
if(playlists.items == null) {
playlists = JSON.parse(playlists);
}
} else {
$(".noresults-error").show();
}
}
}
function yt_onPlaylistClick_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(playlistId)
{
//console.log('click: '+playlistId);
yt_selectPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(playlistId);
}
function yt_selectPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(playlistId)
{
if (playlistId==="FEATURED")
yt_loadFeaturedPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd();
else
yt_loadPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(playlistId);
}
// **************************************************************************************************
// CARGA DE PLAYLIST - PORTADA
function yt_loadFeaturedPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd()
{
var videoList = new Array();
for (var i = 0; i < yt_appData_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd.videoList.length; i++)
if (yt_appData_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd.videoList[i].featured==="true")
videoList_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd.push(yt_appData.videoList[i].videoId);
var jsonURL="https://www.googleapis.com/youtube/v3/videos?part=snippet&maxResults=20&id="+videoList.join()+"&key=AIzaSyDtCXRz3PSPr4lTE4qzQG_wdcQKx0W_rLk";
var request = new XMLHttpRequest();
request.open('GET', jsonURL);
request.responseType = 'json';
request.send();
request.onload = function() {
if (request.status === 200) {
var data = request.response;
if(data.items == null) {
data = JSON.parse(data);
}
yt_renderPlaylistItems_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(true,yt_parsePlaylistItems_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(data));
} else {
$(".noresults-error").show();
}
}
}
// **************************************************************************************************
// CARGA DE PLAYLIST - API
function yt_loadPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(playlistId)
{
var jsonURL="https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&maxResults=20&playlistId="+playlistId+"&key=AIzaSyDtCXRz3PSPr4lTE4qzQG_wdcQKx0W_rLk";
var request = new XMLHttpRequest();
request.open('GET', jsonURL);
request.responseType = 'json';
request.send();
request.onload = function() {
if (request.status === 200) {
var data = request.response;
if(data.items == null) {
data = JSON.parse(data);
}
yt_renderPlaylistItems_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(true,yt_parsePlaylistItems_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(data));
} else {
$(".noresults-error").show();
}
}
}
function yt_parsePlaylistItems_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(data)
{
var videoList = new Array();
for (var i = 0; i < data.items.length; i++) {
//console.log('Procesando: '+data.items[i].snippet.title);
var video = {};
if (data.items[i].snippet.resourceId===undefined)
video.videoId = data.items[i].id; //estamos procesando los videos de portada
else
video.videoId = data.items[i].snippet.resourceId.videoId; //estamos procesando un playlist normal
video.title = data.items[i].snippet.title;
video.date = new Date(data.items[i].snippet.publishedAt);
video.description = data.items[i].snippet.description;
video.thumbnail = data.items[i].snippet.thumbnails.high.url;
//Comprobamos si el video est� registrado en la app de magnolia
var appVideo = yt_getAppVideoData_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(video.videoId);
if (appVideo!==undefined)
video.links = appVideo.links;
videoList.push(video);
}
return videoList;
}
// **************************************************************************************************
// GENERAR NUMERO ALEATORIO DENTRO DEL RANGO VALIDO
var usados_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd = [];
function random_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd (items){
var numVideos = items.length;
var random = Math.floor(Math.random() * (numVideos));
if(usados_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd.indexOf(random)>= 0 || random >= items.length){
return random_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(items);
}else{
usados_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd.push(random);
return random;
}
}
// **************************************************************************************************
// GENERAR LISTADO DE VIDEOS
function yt_renderPlaylistItems_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(cleanup, items)
{
if (cleanup===true)
{
var parent = document.getElementById('yt_playlist_content_items_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
parent.innerHTML = "";
}
for (var i = 0; i < Math.min(3, items.length); i++) {
//console.log('Anyadiendo: '+items[i].title);
var random = random_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(items);
yt_addVideoItem_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(items[random]);
}
}
function yt_addVideoItem_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd (video)
{
var parent = document.getElementById('yt_playlist_content_items_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
var li = document.createElement('div');
li.className="col-xs-12 col-sm-6 col-md-4";
li.style="cursor: pointer";
//li.setAttribute("tabindex", "0");
parent.appendChild(li);
var ddata = document.createElement('div');
ddata.className="card card-blog card-plain";
//ddata.setAttribute("tabindex", "0");
li.appendChild(ddata);
var ddata2 = document.createElement('div');
ddata2.className="card-header card-header-image";
ddata2.onclick = function () {yt_onPlayVideo_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(video)};
ddata2.onkeyup = function (e) {if(e.which == 13 || e.keycode == 13)yt_onPlayVideo_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(video)};
ddata2.setAttribute("tabindex", "0");
ddata.appendChild(ddata2);
var pic = document.createElement('img');
pic.className="img img-raised";
pic.src=video.thumbnail;
pic.alt="video-thumbnail-umivale";
//pic.setAttribute("tabindex", "0");
ddata2.appendChild(pic);
var shadow = document.createElement('div');
shadow.className="colored-shadow";
shadow.style="background-image: url("+ video.thumbnail +"); opacity: 1;";
shadow.onclick = function () {yt_onPlayVideo_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(video)};
ddata2.appendChild(shadow);
var body = document.createElement('div');
body.className="card-body";
ddata.appendChild(body);
var title = document.createElement('h3');
title.className="card-title";
title.style.height='52px';
title.innerText=video.title;
title.onclick = function () {yt_onPlayVideo_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(video)};
body.appendChild(title);
}
// **************************************************************************************************
// PLAYER
function yt_closePlayer_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd()
{
var player = document.getElementById('modal fade_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
var iframe = document.getElementById('youtube-player-iframe-mini_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
iframe.src='about:blank';
player.style.display='none';
}
function yt_closeDetail_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd()
{
var player = document.getElementById('youtube-player_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
player.style.display='none';
player.className="modal fade";
}
function stopVideo() {
playerInstance.stopVideo();
}
function rewind() {
var currentTime = playerInstance.getCurrentTime();
playerInstance.seekTo(currentTime - 30, true);
playerInstance.pauseVideo();
}
function fastforward() {
var currentTime = playerInstance.getCurrentTime();
playerInstance.seekTo(currentTime + 30, true);
playerInstance.pauseVideo();
}
function pause(){
playerInstance.pauseVideo();
}
function play(){
playerInstance.playVideo();
}
function yt_onPlayVideo_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd(video) {
var player = document.getElementById('youtube-player_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
var title = document.getElementById('youtube-player-title_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
var iframe = document.getElementById('youtube-player-iframe-mini_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
var youtubeDate = document.getElementById('youtube-date_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
//console.log(video);
title.innerText=video.title;
iframe.src='https://www.youtube-nocookie.com/embed/' + video.videoId + '?autoplay=1&enablejsapi=1';
iframe.setAttribute("videoid", video.videoId);
player.style.display='block';
player.className="modal show";
$(document).on("keydown", function(event){
return !(event.which == 32 || event.keyCode == 32);
});
//onYouTubeIframeAPIReadyCreateInstance();
$(document).on("keyup", function(event){
if(playerInstance === undefined || playerInstance === null)
onYouTubeIframeAPIReadyCreateInstance();
switch(event.which) {
case 27: // ESC
stopVideo();
var playerElement = document.getElementById('youtube-player_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd');
var iframe = $(player).find("iframe")[0];
iframe.src = "about:blank";
playerElement.style.display='none';
playerElement.className="modal fade";
$(document).off("keyup");
$(document).off("keydown");
break;
case 32: // space (pause/play)
var state = playerInstance.getPlayerState();
if(state==1)
pause();
else
play();
break;
case 37: // left (rewind)
rewind();
break;
case 39: // right (fast-forward)
fastforward();
break;
default: break; // exit this handler for other keys
}
event.preventDefault();
});
}
//yt_loadPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd();
if('listaReproduccion' == 'lista Reproduccion') {
yt_selectPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd("FEATURED");
} else {
yt_loadPlaylist_8b48ec17_ebe2_417a_ad96_3fd1820e5dcd('PLDYBNR0VGdlZLtOPozfCdmUFHKol3pDfN');
}
//*******************************************************************************************************
//GESTION DEL MODAL DEL VIDEO AL ABRIRLO Y CERRARLO
$(".close.youtube-component-close-button").on("click", function(event) {
var parentModal = $(this).closest('[id*="youtube-player_"]')[0];
var iframe = $(parentModal).find("iframe")[0];
iframe.src = "about:blank";
$(document).off("keyup");
$(document).off("keydown");
});
</script>
