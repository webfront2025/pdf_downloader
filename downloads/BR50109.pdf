    <script type="text/javascript">
      let downurl = 'https://www.actron.com.tw/esg/tw/sustainability-report/downfiles1';
      document.addEventListener("DOMContentLoaded", function() {
        const downbtn1s = document.querySelectorAll(".downbtn1");
        downbtn1s.forEach((downbtn1, index) => {
          downbtn1.addEventListener("click", function (e) {
            let val = this.dataset.index;
            if(val) {
              url = downurl + "?gid=" + val;
              fetch(url, { method: "get" })
                .then(function (response) {
                  if (!response.ok) {
                    return response.text().then((text) => {
                      throw new Error(text);
                    });
                  }
                  return response.json();
                })
                .then(function (j) {
                  if (j.error) {
                    alert(j.error);
                    return;
                  }
                  if (j.url) {
                    var ifrm = $("<iframe style='display:none' />");
                    ifrm.attr("src", j.url);
                    ifrm.appendTo("body");
                    ifrm.load(function () {
                      $("body").append("<div>Failed to download !");
                    });
                  }
                })
                .catch(function (err) {});
              }
            });
          });
          let down2url = 'https://www.actron.com.tw/esg/tw/sustainability-report/downfiles2';
          const downbtn2s = document.querySelectorAll(".downbtn2");
          downbtn2s.forEach((downbtn2, index) => {
            downbtn2.addEventListener("click", function (e) {
              let val = this.dataset.index;
              if(val) {
                url = down2url + "?gid=" + val;
                fetch(url, { method: "get" })
                  .then(function (response) {
                    if (!response.ok) {
                      return response.text().then((text) => {
                        throw new Error(text);
                      });
                    }
                    return response.json();
                  })
                  .then(function (j) {
                    if (j.error) {
                      alert(j.error);
                      return;
                    }
                    if (j.url) {
                      var ifrm = $("<iframe style='display:none' />");
                      ifrm.attr("src", j.url);
                      ifrm.appendTo("body");
                      ifrm.load(function () {
                        $("body").append("<div>Failed to download !");
                      });
                    }
                  })
                  .catch(function (err) {});
                }
            });
          });
        });
    </script>
</body>

