<script type="text/javascript">
if (window.location.hash) {
  let number =
    window.location.hash.split("#section")[window.location.hash.split("#section").length - 1];
  if ($('#js-career'+number)) {
    let sectionTarget = $('#js-career'+number).offset().top;
    $('html,body').stop().animate(
      {
        scrollTop: sectionTarget - 80,
      },
      800
    );
  }
}
$(function () {
  $('[name="lselect"]').change(function () {
    top.location.href=$(this).val()
  })
})
</script>
